{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@dietrichgebert/ponytail"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "coder": {
          "name": "coder"
        },
        "glm-47": {
          "name": "glm-47"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "context7-mcp"
      ],
      "enabled": true
    },
    "nixos": {
      "type": "local",
      "command": [
        "nix",
        "run",
        "github:utensils/mcp-nixos",
        "--"
      ]
    },
    "grafana": {
      "type": "local",
      "command": [
        "docker", "run", "-i", "--rm",
        "-e", "GRAFANA_URL",
        "-e", "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "grafana/mcp-grafana",
        "-t", "stdio"
      ],
      "environment": {
        "GRAFANA_URL": "https://monitoring.quoll-ratio.ts.net",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{file:/run/agenix/grafana-sa-token}"
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  }
}
